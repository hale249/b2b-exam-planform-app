{
  "appId": "com.prepedu.exam-platform",
  "productName": "Prep Exam Platform",
  "directories": {
    "buildResources": "resources",
    "output": "dist"
  },
  "publish": {
    "provider": "github",
    "owner": "hale249",
    "repo": "b2b-exam-planform-app"
  },
  "files": [
    "!**/.vscode/*",
    "!src/*",
    "!vite.config.{js,ts,mjs,cjs}",
    "!{.eslintignore,.eslintrc.cjs,.prettierignore,.prettierrc.yaml,CHANGELOG.md,README.md}",
    "!{tsconfig.json,tsconfig.node.json,tsconfig.web.json}"
  ],
  "asarUnpack": [
    "resources/**"
  ],
  "electronFuses": {
    "runAsNode": false,
    "enableNodeOptionsEnvironmentVariable": false,
    "enableNodeCliInspectArguments": false,
    "enableCookieEncryption": false,
    "onlyLoadAppFromAsar": true,
    "enableEmbeddedAsarIntegrityValidation": true
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "artifactName": "${name}-${version}-setup.${ext}",
    "shortcutName": "${productName}",
    "uninstallDisplayName": "${productName}",
    "deleteAppDataOnUninstall": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "mac": {
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "artifactName": "${name}-${version}-${arch}.${ext}",
    "extendInfo": {
      "NSMicrophoneUsageDescription": "Application needs microphone access for the exam.",
      "NSCameraUsageDescription": "Application needs camera access for the exam.",
      "NSDocumentsFolderUsageDescription": "Application needs access for exam files."
    },
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ]
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      }
    ],
    "maintainer": "prepedu.com",
    "category": "Education",
    "artifactName": "${name}-${version}.${ext}"
  },
  "dmg": {
    "artifactName": "${name}-${version}-${arch}.${ext}"
  }
}
