VITE_APP_ENVIRONMENT="production"
VITE_EXAM_URL="https://testing-candidate.prepedu.com"

VITE_API_ANTI_URL=""
VITE_APP_HMAC_SECRET=""

# Debug toggles — MUST stay "false" (or empty) in builds shipped to students.
# VITE_ALLOW_SCREENSHOT="true": disable screen-capture protection (content
#   protection, screenshot shortcut blocking, macOS recording cover) for dev/QA.
# VITE_ALLOW_DEVTOOLS="true": keep DevTools available in a packaged build; F12 /
#   Cmd+Shift+I / Cmd+Shift+J toggle it.
VITE_ALLOW_SCREENSHOT="false"
VITE_ALLOW_DEVTOOLS="false"

