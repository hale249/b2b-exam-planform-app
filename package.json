{
  "name": "b2b-exam-platform-app",
  "version": "1.0.0",
  "description": "Secure Electron exam platform with anti-cheating measures",
  "main": "./dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "clean": "npx rimraf dist dist-electron",
    "build": "npm run clean && vite build",
    "bytecode": "electron scripts/compile-bytecode.cjs",
    "start": "electron .",
    "build:unpack": "npm run clean && vite build && npm run bytecode && electron-builder --dir",
    "build:win": "npm run clean && vite build && npm run bytecode && electron-builder --win",
    "build:mac": "npm run clean && vite build && npm run bytecode && electron-builder --mac",
    "build:linux": "npm run clean && vite build && npm run bytecode && electron-builder --linux",
    "typecheck": "tsc --noEmit --composite false -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,js,json,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,js,json,css,html}\""
  },
  "dependencies": {
    "bytenode": "^1.5.7",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vue-eslint-parser": "^10.4.0"
  }
}
